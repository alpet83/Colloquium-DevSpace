{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CQDS: PostgreSQL backup",
      "type": "shell",
      "command": "docker compose exec colloquium-core sh /app/postgres/backup_postgres.sh",
      "options": {
        "cwd": "${workspaceFolder}/src"
      },
      "problemMatcher": []
    },
    {
      "label": "CQDS: PostgreSQL backup (retention 14d)",
      "type": "shell",
      "command": "docker compose exec -e RETENTION_DAYS=14 colloquium-core sh /app/postgres/backup_postgres.sh",
      "options": {
        "cwd": "${workspaceFolder}/src"
      },
      "problemMatcher": []
    }
  ]
}
